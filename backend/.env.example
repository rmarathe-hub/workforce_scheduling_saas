APP_NAME="Workforce Scheduling SaaS"
# development | production — production blocks local SQS workers when SQS is configured
ENVIRONMENT="development"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres"

# Optional: separate database for pytest (recommended). If unset, tests use DATABASE_URL.
TEST_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres_test"

# Optional: deployed API smoke tests (pytest -m e2e)
E2E_API_BASE_URL="https://your-api.onrender.com"

JWT_SECRET_KEY="replace-me"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

FRONTEND_URL="http://localhost:5173"


AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=shiftops-documents-rohit-marathe
SQS_NOTIFICATION_QUEUE_URL=

